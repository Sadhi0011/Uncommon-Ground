# ----------------------------------------------------------------------------
# Server
# ----------------------------------------------------------------------------
PORT=4000
NODE_ENV=development

# Comma-separated list of allowed front-end origins (CORS)
CLIENT_ORIGIN=http://localhost:5173

# ----------------------------------------------------------------------------
# PostgreSQL
# Either set DATABASE_URL, or the individual PG* values below.
# ----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/uncommon_ground
# PGHOST=localhost
# PGPORT=5432
# PGUSER=postgres
# PGPASSWORD=postgres
# PGDATABASE=uncommon_ground

# Set to true if your Postgres requires SSL (e.g. Neon, Render, Supabase)
PGSSL=false

# ----------------------------------------------------------------------------
# Auth
# ----------------------------------------------------------------------------
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=7d

# ----------------------------------------------------------------------------
# Default admin account (seeded on first run)
# ----------------------------------------------------------------------------
ADMIN_NAME=Site Admin
ADMIN_EMAIL=admin@uncommonground.com
ADMIN_PASSWORD=Admin@12345

# ----------------------------------------------------------------------------
# Email (SMTP via Nodemailer)
# Leave SMTP_HOST blank to disable sending (the app still works; mail is logged
# as skipped). For Gmail use smtp.gmail.com:465 (SECURE=true) with an App Password.
# ----------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM_NAME=Uncommon Ground
MAIL_FROM=sadaiah.r@d3e.studio
CONTACT_TO=sadaiah.r@d3e.studio
